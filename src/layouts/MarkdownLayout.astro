---
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import CopyCodeButton from "../components/CopyCodeButton.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  ogImage?: string;
  readingTime?: number;
  linkTags?: boolean;
  prevPost?: { title: string; slug: string };
  nextPost?: { title: string; slug: string };
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  ogImage,
  readingTime,
  linkTags = false,
  prevPost,
  nextPost,
} = Astro.props;
---

<BaseLayout title={`${title} — Rui André Batista`} description={description} ogImage={ogImage}>
  <article>
    <header class="article-header">
      <h1>{title}</h1>
      <div class="article-meta">
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <span class="updated">
              (updated <FormattedDate date={updatedDate} />)
            </span>
          )
        }
        {readingTime && <span class="reading-time">{readingTime} min read</span>}
      </div>
      {
        tags.length > 0 && (
          <ul class="tag-list" role="list" aria-label="Tags">
            {tags.map((tag) => (
              <li>
                {linkTags ? (
                  <a href={`/blog/tag/${tag}/`} class="tag">
                    {tag}
                  </a>
                ) : (
                  <span class="tag">{tag}</span>
                )}
              </li>
            ))}
          </ul>
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
    <CopyCodeButton />
  </article>

  {
    (prevPost || nextPost) && (
      <nav class="post-nav" aria-label="Previous and next posts">
        <div class="post-nav-item">
          {prevPost && (
            <a href={`/blog/${prevPost.slug}/`}>
              <span class="post-nav-label">← Previous</span>
              <span class="post-nav-title">{prevPost.title}</span>
            </a>
          )}
        </div>
        <div class="post-nav-item post-nav-next">
          {nextPost && (
            <a href={`/blog/${nextPost.slug}/`}>
              <span class="post-nav-label">Next →</span>
              <span class="post-nav-title">{nextPost.title}</span>
            </a>
          )}
        </div>
      </nav>
    )
  }
</BaseLayout>

<style>
  .article-header {
    margin-block-end: var(--space-2xl);
    padding-block-end: var(--space-lg);
    border-block-end: 1px solid var(--color-border);
  }

  h1 {
    margin-block-end: var(--space-sm);
  }

  .article-meta {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .updated {
    color: var(--color-text-subtle);
  }

  .reading-time {
    margin-inline-start: var(--space-md);
    color: var(--color-text-subtle);
  }

  .reading-time::before {
    content: "·  ";
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin-block-start: var(--space-md);
  }

  .tag-list a.tag {
    text-decoration: none;
    color: var(--color-text-muted);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .tag-list a.tag:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin-block-start: var(--space-3xl);
    padding-block-start: var(--space-xl);
    border-block-start: 1px solid var(--color-border);
  }

  .post-nav-item a {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-decoration: none;
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-fast);
  }

  .post-nav-item a:hover {
    border-color: var(--color-text-subtle);
  }

  .post-nav-next {
    text-align: end;
  }

  .post-nav-label {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-subtle);
  }

  .post-nav-title {
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }
</style>
