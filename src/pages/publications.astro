---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Publications — Rui André Batista"
  description="Talks, articles, and other publications by Rui André Batista."
>
  <header class="page-header">
    <h1>
      <span class="prefix" aria-hidden="true">~/</span>publications
    </h1>
    <p>Talks, articles, and other things I've put out there.</p>
  </header>

  <section aria-labelledby="talks-heading">
    <h2 id="talks-heading">Talks</h2>
    <div class="entries">
      <article class="entry">
        <div class="entry-header">
          <h3>O Braille e a Inteligência Artificial — Oportunidades e Desafios</h3>
          <span class="entry-date">Jan 15, 2026</span>
        </div>
        <p class="entry-venue">
          Instituto Nacional para a Reabilitação — Dia Mundial do Braille
        </p>
        <p>Panel moderator. Webinar on Braille and artificial intelligence. In Portuguese.</p>
      </article>

      <article class="entry">
        <div class="entry-header">
          <h3>
            <a
              href="https://www.confluent.io/events/kafka-summit-london-2024/building-a-scalable-real-time-fleet-management-iot-data-tracker-with-kafka/"
              target="_blank"
              rel="noopener"
            >
              Building a Scalable Real-Time Fleet Management IoT Data Tracker
              with Kafka Streams and gRPC
              <span class="external-hint" aria-hidden="true">&nearr;</span>
            </a>
          </h3>
          <span class="entry-date">Mar 2024</span>
        </div>
        <p class="entry-venue">Kafka Summit London 2024</p>
        <p>With Adrien Bestel.</p>
      </article>

      <article class="entry">
        <div class="entry-header">
          <h3>Functional Programming and Concurrency Walk into a Bar</h3>
          <span class="entry-date">Jul 2019</span>
        </div>
        <p class="entry-venue">LXScala &amp; Reactive 2019</p>
      </article>

      <article class="entry">
        <div class="entry-header">
          <h3>
            <a
              href="https://www.youtube.com/watch?v=fwQMdxYPRIo"
              target="_blank"
              rel="noopener"
            >
              Functional Streams with Kafka: Reactive-kafka vs FS2
              <span class="external-hint" aria-hidden="true">&nearr;</span>
            </a>
          </h3>
          <span class="entry-date">May 2017</span>
        </div>
        <p class="entry-venue">LXScala 2017</p>
        <p>With Luís Reis.</p>
      </article>

      <article class="entry">
        <div class="entry-header">
          <h3>NVDA — Um Leitor de Ecrã Livre para Microsoft Windows</h3>
          <span class="entry-date">Apr 2012</span>
        </div>
        <p class="entry-venue">Infotec'12 — Instituto Politécnico de Castelo Branco</p>
        <p>NVDA — A free screen reader for Microsoft Windows. In Portuguese.</p>
      </article>
    </div>
  </section>

  <section aria-labelledby="articles-heading">
    <h2 id="articles-heading">Articles</h2>
    <div class="entries">
      <article class="entry">
        <div class="entry-header">
          <h3>
            <a
              href="https://www.pcguia.pt/2025/11/usar-o-leitor-de-ecra-nvda-para-ler-sites/"
              target="_blank"
              rel="noopener"
            >
              Usar o Leitor de Ecrã NVDA para Ler Sites
              <span class="external-hint" aria-hidden="true">&nearr;</span>
            </a>
          </h3>
          <span class="entry-date">Nov 2025</span>
        </div>
        <p class="entry-venue">PCGuia</p>
        <p>Using the NVDA screen reader to read websites. In Portuguese.</p>
      </article>

      <article class="entry">
        <div class="entry-header">
          <h3>
            <a
              href="https://medium.com/tblx-insider/being-a-blind-engineer-at-tb-lx-98c4a0dfaece"
              target="_blank"
              rel="noopener"
            >
              Being a Blind Engineer at TB.LX
              <span class="external-hint" aria-hidden="true">&nearr;</span>
            </a>
          </h3>
          <span class="entry-date">Oct 2023</span>
        </div>
        <p class="entry-venue">TB.LX Insider — Medium</p>
        <p>Tools, workflow, and workplace adaptation as a blind backend engineer.</p>
      </article>

      <article class="entry">
        <div class="entry-header">
          <h3>
            <a
              href="https://proandee.weebly.com/uploads/1/6/4/6/16461788/caderno_braille_porqu%C3%AA__4jan2022.pdf"
              target="_blank"
              rel="noopener"
            >
              O Braille e as Novas Tecnologias: a Perspectiva Nerd
              <span class="external-hint" aria-hidden="true">&nearr;</span>
            </a>
          </h3>
          <span class="entry-date">2022</span>
        </div>
        <p class="entry-venue">Braille, Porquê? — Associação Bengala Mágica</p>
        <p>Braille and new technologies: the nerd perspective. In Portuguese.</p>
      </article>

      <article class="entry">
        <div class="entry-header">
          <h3>
            <a
              href="https://www.acapo.pt/sites/default/files/media/2018/publicacoes/revista_louis_braille_edicao_n.o24_0.pdf"
              target="_blank"
              rel="noopener"
            >
              Tecnologia, Orientação e Mobilidade: Algumas Considerações
              <span class="external-hint" aria-hidden="true">&nearr;</span>
            </a>
          </h3>
          <span class="entry-date">2018</span>
        </div>
        <p class="entry-venue">Revista Louis Braille, edição 24 — ACAPO</p>
        <p>Technology, orientation and mobility: some considerations. In Portuguese.</p>
      </article>

      <article class="entry">
        <div class="entry-header">
          <h3>
            <a
              href="https://www.acapo.pt/nvda-um-exemplo-de-autorrepresentacao"
              target="_blank"
              rel="noopener"
            >
              NVDA, Um Exemplo de Autorrepresentação
              <span class="external-hint" aria-hidden="true">&nearr;</span>
            </a>
          </h3>
          <span class="entry-date">2017</span>
        </div>
        <p class="entry-venue">Revista Louis Braille, edição 21 — ACAPO</p>
        <p>NVDA, an example of self-representation. In Portuguese.</p>
      </article>

      <article class="entry">
        <div class="entry-header">
          <h3>
            <a
              href="https://www.acapo.pt/sites/default/files/revista_louis_braille_edicao_n.o19.pdf"
              target="_blank"
              rel="noopener"
            >
              Jogos Acessíveis
              <span class="external-hint" aria-hidden="true">&nearr;</span>
            </a>
          </h3>
          <span class="entry-date">2016</span>
        </div>
        <p class="entry-venue">Revista Louis Braille, edição 19 — ACAPO</p>
        <p>Accessible games for blind and low-vision people. In Portuguese.</p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-block-end: var(--space-2xl);
  }

  .prefix {
    color: var(--color-text-subtle);
  }

  .page-header p {
    color: var(--color-text-muted);
    margin-block-start: var(--space-sm);
  }

  section {
    margin-block-end: var(--space-3xl);
  }

  h2 {
    font-size: var(--font-size-lg);
    padding-block-end: var(--space-sm);
    border-block-end: 1px solid var(--color-border);
    margin-block-end: var(--space-lg);
  }

  .entries {
    display: grid;
    gap: var(--space-xl);
  }

  .entry-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .entry h3 {
    font-size: var(--font-size-base);
  }

  .entry h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .entry h3 a:hover {
    color: var(--color-accent);
  }

  .external-hint {
    font-size: 0.75em;
    color: var(--color-text-subtle);
  }

  .entry-date {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-subtle);
    white-space: nowrap;
  }

  .entry-venue {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-accent);
    margin-block-end: var(--space-sm);
  }

  .entry > p:last-child {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
