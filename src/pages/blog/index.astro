---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
  title="Blog — Rui André Batista"
  description="Articles on software engineering, accessibility, and open source."
>
  <header class="page-header">
    <h1>
      <span class="prefix" aria-hidden="true">~/</span>blog
    </h1>
    <p>Software engineering, accessibility, and the occasional war story.
      <a href="/rss.xml" class="rss-link">RSS</a>
    </p>
  </header>

  {
    posts.length > 0 ? (
      <div class="post-list">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
      </div>
    ) : (
      <p class="empty">No posts yet. Check back soon.</p>
    )
  }
</BaseLayout>

<style>
  .page-header {
    margin-block-end: var(--space-2xl);
  }

  .prefix {
    color: var(--color-text-subtle);
  }

  .page-header p {
    color: var(--color-text-muted);
    margin-block-start: var(--space-sm);
  }

  .rss-link {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-subtle);
    margin-inline-start: var(--space-sm);
  }

  .post-list {
    display: grid;
    gap: var(--space-md);
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
