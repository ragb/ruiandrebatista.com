---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";
import { getCollection } from "astro:content";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const posts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
  return paginate(posts, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout
  title={page.currentPage === 1 ? "Blog — Rui André Batista" : `Blog — Page ${page.currentPage} — Rui André Batista`}
  description="Articles on software engineering, accessibility, and open source."
>
  <header class="page-header">
    <h1>
      <span class="prefix" aria-hidden="true">~/</span>blog
    </h1>
    <p>Software engineering, accessibility, and the occasional war story.
      <a href="/rss.xml" class="rss-link">RSS</a>
    </p>
  </header>

  {
    page.data.length > 0 ? (
      <div class="post-list">
        {page.data.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.id}
            tags={post.data.tags}
          />
        ))}
      </div>
    ) : (
      <p class="empty">No posts yet. Check back soon.</p>
    )
  }

  {
    page.lastPage > 1 && (
      <nav class="pagination" aria-label="Blog pages">
        {page.url.prev ? (
          <a href={page.url.prev} class="pagination-link">&larr; Newer</a>
        ) : (
          <span />
        )}
        <span class="pagination-info">
          Page {page.currentPage} of {page.lastPage}
        </span>
        {page.url.next ? (
          <a href={page.url.next} class="pagination-link">Older &rarr;</a>
        ) : (
          <span />
        )}
      </nav>
    )
  }
</BaseLayout>

<style>
  .page-header {
    margin-block-end: var(--space-2xl);
  }

  .prefix {
    color: var(--color-text-subtle);
  }

  .page-header p {
    color: var(--color-text-muted);
    margin-block-start: var(--space-sm);
  }

  .rss-link {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-subtle);
    margin-inline-start: var(--space-sm);
  }

  .post-list {
    display: grid;
    gap: var(--space-md);
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-block-start: var(--space-2xl);
    padding-block-start: var(--space-lg);
    border-block-start: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
  }

  .pagination-link {
    color: var(--color-text-muted);
    text-decoration: none;
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .pagination-link:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  .pagination-info {
    color: var(--color-text-subtle);
  }
</style>
