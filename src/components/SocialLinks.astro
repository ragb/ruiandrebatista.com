---
interface Props {
  class?: string;
}

const socials = [
  {
    label: "GitHub",
    href: "https://github.com/ragb",
    icon: "github",
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/rui-batista-59b90215/",
    icon: "linkedin",
  },
  {
    label: "Mastodon",
    href: "https://masto.pt/@ragb",
    icon: "mastodon",
    rel: "me",
  },
];
---

<ul class:list={["social-links", Astro.props.class]} role="list">
  {
    socials.map((s) => (
      <li>
        <a
          href={s.href}
          target="_blank"
          rel={s.rel ? `noopener ${s.rel}` : "noopener"}
          aria-label={`${s.label} (opens in new tab)`}
        >
          {s.icon === "github" && (
            <svg
              aria-hidden="true"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
            </svg>
          )}
          {s.icon === "linkedin" && (
            <svg
              aria-hidden="true"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          )}
          {s.icon === "mastodon" && (
            <svg
              aria-hidden="true"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.547c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054 19.648 19.648 0 0 0 4.636.536c.562 0 1.124-.02 1.685-.06 1.969-.142 4.076-.442 5.674-1.171 3.755-1.713 3.753-7.075 3.753-7.075 0-.177.007-3.478-.15-4.96zm-3.39 8.072h-2.81v-7.42c0-1.564-.658-2.358-1.976-2.358-1.458 0-2.188 0.942-2.188 2.806v4.058h-2.794V6.413c0-1.864-.73-2.806-2.188-2.806-1.318 0-1.976.794-1.976 2.358v7.42H3.136V5.958c0-1.564.4-2.809 1.2-3.734.825-.926 1.907-1.401 3.247-1.401 1.55 0 2.726.596 3.51 1.788l.756 1.267.757-1.267c.783-1.192 1.96-1.788 3.51-1.788 1.34 0 2.422.475 3.246 1.401.8.925 1.2 2.17 1.2 3.734v8.427z" />
            </svg>
          )}
        </a>
      </li>
    ))
  }
</ul>

<style>
  .social-links {
    display: flex;
    gap: var(--space-sm);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  a {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xs);
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast);
    text-decoration: none;
  }

  a:hover {
    color: var(--color-text);
  }
</style>
